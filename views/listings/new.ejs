<% layout("layouts/boilerplate.ejs") %>

<div class="row mt-2">
    <div class="col-8 offset-2">
        <h3>Create a New Listing</h3>
        <form method="POST" action="/listings" class="new-listing-form">
                    <div class="mb-3 form-lable">
                        <label>Title</label>
                        <input class="form-control" name="listing[title]" type="text" required>
                    </div>

                    <div class="mb-3 form-lable">
                        <label>Description</label>
                        <textarea class="form-control" name="listing[description]" type="text" required> </textarea>
                    </div>
                    
                    <div class="mb-3 form-lable">
                        <label for="image">Image</label>
                        <input class="form-control" name="listing[image]" type="text" >
                    </div>

                    <div class="row">
                        <div class="mb-3 form-lable col-md-4">
                            <label for="">Price</label>
                            <input class="form-control" name="listing[price]" type="number" required>
                        </div>
                    
                        <div class="mb-3 form-lable col-md-4">
                            <label for="">Location</label>
                            <input class="form-control" name="listing[location]" type="text" required>
                        </div>
                    </div>
                
                    <div class="mb-3 form-lable">
                        <label for="">Country</label>
                        <input class="form-control" name="listing[country]" type="text" required>
                    </div>

                    <button class="btn btn-primary">Add Listing</button>
                    <br> <br>
        </form>
    </div>
</div>
        